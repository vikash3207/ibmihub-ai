# IBMiHub AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to the repository.

# ─── Supabase ───────────────────────────────────────────────────────────────
# From: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — server-side ONLY; bypasses RLS; NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI Provider ────────────────────────────────────────────────────────────
# PLACEHOLDER ONLY — do not add a real key until IMP-Q-007 is resolved.
# Verify exact model IDs, pricing, and rate limits against official Anthropic
# documentation before populating this value or installing the Anthropic SDK.
ANTHROPIC_API_KEY=placeholder-verify-before-use
