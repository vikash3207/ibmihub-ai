# Dependencies
node_modules

# Next.js build output
.next
out

# Environment files -- never commit real secrets
.env.local
.env.*.local

# TypeScript incremental build cache
*.tsbuildinfo

# ESLint cache
.eslintcache

# Claude Code local settings (machine-specific, not shared)
.claude/settings.local.json
.claude/*.local.json

# OS metadata
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Unused lock files -- only package-lock.json (npm) is committed
yarn.lock
pnpm-lock.yaml
